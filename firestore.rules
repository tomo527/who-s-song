rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isHost(roomId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid;
    }

    function isRoomMember(roomId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid));
    }

    function isCurrentParent(roomId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.currentRoundId != ''
        && get(/databases/$(database)/documents/rooms/$(roomId)/rounds/$(get(/databases/$(database)/documents/rooms/$(roomId)).data.currentRoundId)).data.parentPlayerId == request.auth.uid;
    }

    function isRequestedRoundParent(roomId) {
      return isSignedIn()
        && request.resource.data.currentRoundId != ''
        && exists(/databases/$(database)/documents/rooms/$(roomId)/rounds/$(request.resource.data.currentRoundId))
        && get(/databases/$(database)/documents/rooms/$(roomId)/rounds/$(request.resource.data.currentRoundId)).data.parentPlayerId == request.auth.uid;
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isHost(roomId) ||
        (
          isRoomMember(roomId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'currentRoundId',
            'currentRoundNumber',
            'status',
          ]) &&
          (
            isCurrentParent(roomId) ||
            isRequestedRoundParent(roomId)
          )
        )
      );

      match /players/{playerId} {
        allow read: if true;
        allow create: if isSignedIn() && request.auth.uid == playerId;
        allow update: if isSignedIn() && (
          request.auth.uid == playerId ||
          isHost(roomId) ||
          isCurrentParent(roomId)
        );
      }

      match /rounds/{roundId} {
        allow read: if true;
        allow create: if isSignedIn() && (
          isHost(roomId) ||
          request.resource.data.parentPlayerId == request.auth.uid
        );
        allow update: if isSignedIn() && (
          isHost(roomId) ||
          resource.data.parentPlayerId == request.auth.uid ||
          (
            isRoomMember(roomId)
            && request.auth.uid != resource.data.parentPlayerId
            && resource.data.phase == 'judging'
            && request.resource.data.phase == 'revealing'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'phase',
              'phaseStartedAt',
            ])
          )
        );
      }

      match /submissions/{submissionId} {
        allow read: if isRoomMember(roomId);
        allow create: if isSignedIn()
          && request.resource.data.playerId == request.auth.uid
          && get(/databases/$(database)/documents/rooms/$(roomId)/rounds/$(request.resource.data.roundId)).data.parentPlayerId != request.auth.uid;
        allow update, delete: if false;
      }

      match /guesses/{guessId} {
        allow read: if isSignedIn() && (
          isCurrentParent(roomId) ||
          (
            resource != null &&
            (
              resource.data.playerId == request.auth.uid ||
              (
                isRoomMember(roomId) &&
                get(/databases/$(database)/documents/rooms/$(roomId)/rounds/$(resource.data.roundId)).data.phase in ['judging', 'revealing']
              ) ||
              get(/databases/$(database)/documents/rooms/$(roomId)/rounds/$(resource.data.roundId)).data.scoreFinalized == true
            )
          )
        );
        allow create: if isSignedIn()
          && request.resource.data.playerId == request.auth.uid
          && get(/databases/$(database)/documents/rooms/$(roomId)/rounds/$(request.resource.data.roundId)).data.parentPlayerId == request.auth.uid;
        allow update: if isSignedIn() && (
          (
            request.resource.data.playerId == request.auth.uid
            && get(/databases/$(database)/documents/rooms/$(roomId)/rounds/$(request.resource.data.roundId)).data.parentPlayerId == request.auth.uid
          ) ||
          (
            resource != null
            && isRoomMember(roomId)
            && request.auth.uid != resource.data.playerId
            && get(/databases/$(database)/documents/rooms/$(roomId)/rounds/$(resource.data.roundId)).data.phase == 'judging'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'isTextAnswerCorrect',
              'judgedByPlayerId',
            ])
            && request.resource.data.judgedByPlayerId == request.auth.uid
          )
        );
        allow delete: if false;
      }
    }
  }
}
