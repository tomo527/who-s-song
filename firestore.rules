rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isHost(roomId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid;
    }

    function isRoomMember(roomId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid));
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isHost(roomId) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'currentRoundId',
          'currentRoundNumber',
          'status',
        ])
      );

      match /players/{playerId} {
        allow read: if true;
        allow create, update: if isSignedIn() && request.auth.uid == playerId;
      }

      match /rounds/{roundId} {
        allow read: if true;
        allow create, update: if isHost(roomId);
      }

      match /submissions/{submissionId} {
        allow read: if isRoomMember(roomId);
        allow create: if isSignedIn() && request.resource.data.playerId == request.auth.uid;
        allow update, delete: if false;
      }

      match /guesses/{guessId} {
        allow read: if isSignedIn() && (
          resource.data.playerId == request.auth.uid ||
          get(/databases/$(database)/documents/rooms/$(roomId)/rounds/$(resource.data.roundId)).data.scoreFinalized == true
        );
        allow create, update: if isSignedIn() && request.resource.data.playerId == request.auth.uid;
        allow delete: if false;
      }
    }
  }
}
